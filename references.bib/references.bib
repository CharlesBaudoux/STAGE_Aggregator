@article{rakesh_kumar_pathak_xai-based_2026,
	title = {{XAI}-{Based} {Evaluation} {Model} for {Navigating} {Academic} {Ambiguity}},
	copyright = {https://creativecommons.org/licenses/by-sa/4.0},
	issn = {2583-7117},
	url = {https://ijisem.com/journal/index.php/ijisem/article/view/526},
	doi = {10.69968/ijisem.2026v5Si153-58},
	abstract = {Academic evaluation often does not reflects student’s abilities accurately. There are sufficient testaments available which proves that student who did not scored well in their academic examinations have done exceptionally well in competitive exams have done very well in their life.   Academic evaluation often becomes unclear because instructions are interpreted differently by teachers, raters score inconsistently, and automated grading systems are not transparent. Till date our assessment modules are largely based on memory based evaluation and not on ability based assessment. This paper suggests using an Explainable AI (XAI)–based evaluation model to reduce this ambiguity by:
1) Making automated and mixed (human + AI) scoring more transparent,
2) Showing clear explanations for each feature and each student’s score, and
3) Providing measurable data that can help improve rubrics.
We include a synthetic-data experiment to show how an easy-to-understand model and XAI methods can

Highlight the main factors affecting grades and
Detect where strict grading or peer-review differences create ambiguity.

The findings show that XAI can offer practical insights that make academic assessment clearer, fairer, and more trustworthy. The paper ends with key suggestions and areas for future research},
	urldate = {2026-07-02},
	journal = {International Journal of Innovations in Science, Engineering And Management},
	author = {{Rakesh Kumar Pathak} and {Prakash Upadhyay}},
	month = may,
	year = {2026},
	pages = {53--58},
	file = {Full Text PDF:files/221/Rakesh Kumar Pathak et Prakash Upadhyay - 2026 - XAI-Based Evaluation Model for Navigating Academic Ambiguity.pdf:application/pdf},
}

@article{jindia_fair_2024,
	title = {{FAIR} {AND} {TRANSPARENT} {STUDENT} {PLACEMENT} {PREDICTIONS}: {A} {MACHINE} {LEARNING} {AND} {EXPLAINABLE} {AI} ({XAI}) {APPROACH}},
	volume = {5},
	issn = {2582-7472},
	shorttitle = {{FAIR} {AND} {TRANSPARENT} {STUDENT} {PLACEMENT} {PREDICTIONS}},
	url = {https://www.granthaalayahpublication.org/Arts-Journal/ShodhKosh/article/view/5996},
	doi = {10.29121/shodhkosh.v5.i4.2024.5996},
	abstract = {Career path prediction plays a vital role in guiding students towards successful careers by offering personalized recommendations based on academic performance, skills, interests, and market trends. Early career path identification allows students to develop relevant skills and gain necessary experience, increasing their competitiveness in the job market. This study aims to ensure fair and transparent predictions by leveraging Machine Learning (ML) and Explainable AI (XAI) techniques on student career dataset. Initially, ML algorithms were applied to predict placement status, followed by an assessment of the model for bias using XAI. Upon detecting bias, mitigation strategies were implemented to enhance fairness. The use of XAI techniques improved model transparency and trustworthiness, allowing stakeholders to understand and trust the decision-making process. The methodology involved identifying and addressing dataset imbalances that could skew predictions. By applying oversampling techniques, the dataset was balanced, leading to significant improvements in model performance. The initial model showed poor performance metrics due to data imbalance, but after oversampling, the F1 score improved. Further application of XAI techniques, such as Local Interpretable Model-agnostic Explanations (LIME) and SHapely Additive exPlanation (SHAP), provided deeper insights into the model's decision-making process. This analysis highlighted specific features that, when oversampled, further enhanced the F1 score. The study emphasizes the importance of using XAI to not only improve mod el performance but also provide a trustworthy framework for stakeholders. By evaluating models using metrics like recall, precision, accuracy, and F1 score, the study demonstrated that integrating fairness and transparency into predictive models is achievable and beneficial for ensuring equitable student placement outcomes.},
	number = {4},
	urldate = {2026-07-02},
	journal = {ShodhKosh: Journal of Visual and Performing Arts},
	author = {Jindia, Anjali and Chawla, Sonal},
	month = apr,
	year = {2024},
}

@article{ganduboina_meta-suite_2024,
	title = {Meta-{Suite}: {An} innovative app for interactive, accessible, and transparent meta-analysis using {R}-{Shiny}.},
	volume = {1},
	copyright = {https://creativecommons.org/licenses/by/4.0},
	issn = {3033-4470},
	shorttitle = {Meta-{Suite}},
	url = {https://impact-surgery.org/index.php/pub/article/view/84},
	doi = {10.62463/surgery.84},
	abstract = {Introduction: Meta-analysis is a powerful model for combining findings from multiple studies on a topic. Due to the growing complexity and amount of data in the digital age, research requires user-friendly tools for complex data analysis. This IDEAL phase2a study introduces Meta-Suite, which aims to simplify statistical analysis for meta-analysis with R.
Methods: Meta-Suite was developed with R and Shiny to provide an intuitive General User Interface (GUI) for meta-analyses. It combines various R programs, such as meta, metasens, and metafor, and provides tools for data visualization, risk of bias evaluation, and quality assessment of randomized controlled trials and observational studies.
Results: Meta-Suite facilitates data input, analysis, and visualization simply, enabling users to focus on their academic writing and reducing statistical analysis load. The application allows for plot customization and provides quick feedback, which improves data understanding and decision-making. It can assist in conducting meta-analyses, creating plots, and downloading them using a user-friendly interface.
Conclusion: Meta-Suite offers a simple and user-friendly interface for conducting meta-analyses, allowing novice to access complex statistical methods. Robost user validation tests are now required to test and improve its functionality.},
	number = {5},
	urldate = {2026-07-02},
	journal = {Impact Surgery},
	author = {Ganduboina, Rohit and Dutta, Palak and Pawar, Shubadarshini and Mukherjee, Indraneil},
	month = sep,
	year = {2024},
	pages = {195--198},
}

@article{chonov_designing_2025,
	title = {{DESIGNING} {EVALUATION} {SYSTEM} {OF} {ACADEMIC} {STAFF} {IN} {CASE} {OF} {ALA}-{TOO} {INTERNATIONAL} {UNIVERSITY}},
	volume = {20},
	issn = {1694-7916, 1694-5263},
	url = {https://ojs.alatoo.edu.kg/index.php/AAS/article/view/14},
	doi = {10.17015/aas.2025.252.13},
	abstract = {This research is aimed at developing a comprehensive assessment system for the faculty of Ala-Too International University, meeting the growing need for a structured, fair and transparent approach to evaluating the effectiveness of teaching, research contributions and service engagement. Current assessment practices are often based on traditional metrics that may not fully reflect the teacher's impact on student achievement, research innovation, and community engagement. This study examines the limitations of existing assessment systems and proposes a holistic model adapted to the specific cultural, institutional and academic environment of Ala-Too International University and aims to improve the evaluation system of academic staff.
          , 
            Бул изилдөө “Ала-Тоо” Эл аралык университетинин профессордук-окутуучулук курамын баалоонун комплекстүү системасын иштеп чыгууга багытталган, ал окутуунун натыйжалуулугун, изилдөө салымдарын жана кызматка катышуусун баалоодо структуралаштырылган, адилеттүү жана ачык-айкын мамилеге болгон муктаждыкты канааттандырат. Учурдагы баалоо практикасы көбүнчө салттуу ченемдерге негизделет, алар окутуучунун окуучулардын жетишкендиктерине, илимий изилдөө инновацияларына жана коомчулуктун катышуусуна толук таасирин чагылдырбашы мүмкүн. Бул изилдөө учурдагы баалоо тутумдарынын чектөөлөрүн карайт жана: “Ала-Тоо” Эл аралык университетинин конкреттүү маданий, институционалдык жана академиялык чөйрөсүнө ылайыкташтырылган бирдиктүү моделди сунуш кылат жана профессордук-окутуучулук курамын баалоо системасын жакшыртууга арналат.
          , 
            Это исследование направлено на разработку комплексной системы оценки профессорско-преподавательского состава Международного университета «Ала Тоо», удовлетворяет растущую потребность в структурированном, справедливом и прозрачном подходе к оценке эффективности преподавания, исследовательского вклада и вовлеченности в обслуживание. Нынешняя практика оценки часто основывается на традиционных показателях, которые могут не отражать в полной мере влияние преподавателя на успеваемость учащихся, инновации в научных исследованиях и вовлечение сообщества. В этом исследовании рассматриваются ограничения существующих систем оценки и предлагается целостная модель, адаптированная к конкретной культурной, институциональной и академической среде Международного университета «Ала-Тоо» и нацелено на улучшение системы оценки профессорско преподавательского состава.},
