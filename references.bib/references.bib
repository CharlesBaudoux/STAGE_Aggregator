@article{kilova_modern_2017,
	title = {{MODERN} {MODELS} {AND} {APPROACHES} {FOR} {DESIGN} {OF} {ARCHITECTURE} {OF} {A} {SOFTWARE} {APPLICATION} {FOR} {MONITORING} {AND} {QUALITY} {ASSESSMENT} {IN} {HIGHER} {EDUCATION}},
